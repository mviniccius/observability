{
  "uid": "observability-api",
  "title": "Observabilidade da API",
  "tags": ["api", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "RPS (Requisições por Segundo)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 2,
      "title": "Tempo Médio de Resposta",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "s",
          "decimals": 3
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_request_duration_seconds_sum[1m])) / sum(rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "Avg"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tempo Máximo de Resposta (p99)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s",
          "decimals": 3
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Percentual de Erros",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "decimals": 2
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_errors_total[1m])) / sum(rate(http_requests_total[1m])) * 100",
          "legendFormat": "Erros %"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total de Requisições",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 4, "h": 3 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "#2563EB", "mode": "fixed" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 6,
      "title": "Uso de CPU (%)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 4, "w": 4, "h": 3 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(api_process_cpu_seconds_total[1m]) * 100",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 7,
      "title": "Uso de Memória (MB)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 4, "w": 4, "h": 3 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 350 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "api_process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "Memória"
        }
      ]
    },
    {
      "id": 8,
      "title": "Requisições por Segundo (série temporal)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (method) (rate(http_requests_total[1m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Latência por Rota (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Distribuição de Códigos HTTP",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 15, "w": 8, "h": 8 },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (status_code) (http_requests_total)",
          "legendFormat": "HTTP {{status_code}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Erros ao Longo do Tempo",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 15, "w": 16, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "#ef4444", "mode": "fixed" },
          "custom": { "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (status_code) (rate(http_errors_total[1m]))",
          "legendFormat": "HTTP {{status_code}}"
        }
      ]
    }
  ]
}
